# Application
APP_NAME=SuperBizAgent
DEBUG=False
HOST=0.0.0.0
PORT=9900

# DashScope / Qwen
# Required. Create your own key in Alibaba Cloud Model Studio.
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# RAG
RAG_TOP_K=3
RAG_MODEL=qwen-max

# Document chunking
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# MCP services
# Local FastMCP services use streamable-http.
# Hosted Tencent Cloud MCP SSE endpoints usually use sse.
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# Prometheus
# For local demos, start-windows.bat starts a Prometheus-compatible mock on 9090
# when no real Prometheus service is already listening on that port.
PROMETHEUS_BASE_URL=http://127.0.0.1:9090
PROMETHEUS_REQUEST_TIMEOUT=10.0
